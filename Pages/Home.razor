@if (showLightbox && currentGallery.Count > 0)
{
    <div class="lightbox-backdrop" @onclick="CloseGallery">
        <div class="lightbox-modal" @onclick:stopPropagation="true">
            <button class="lightbox-close" @onclick="CloseGallery">×</button>
            <button class="lightbox-nav prev" @onclick="PrevImage">❮</button>

            <div class="lightbox-image-wrapper">
                <img src="@currentGallery[currentImageIndex]"
                     alt="Imagem ampliada"
                     class="lightbox-image" />
            </div>

            <button class="lightbox-nav next" @onclick="NextImage">❯</button>
        </div>
    </div>
}

@if (showGame)
{
    <div class="game-backdrop" @onclick="CloseGame">
        <div class="game-modal" @onclick:stopPropagation="true">
            <button class="game-close" @onclick="CloseGame">&times;</button>
            <iframe src="/games/resgatenatalino/index.html"></iframe>
        </div>
    </div>
}

@code {
    private bool showLightbox = false;
    private List<string> currentGallery = new();
    private int currentImageIndex = 0;

    private readonly List<string> projetoTerraImages = new()
    {
        "/images/projeto-terra.jpg",
        "/images/projeto-terra-2.jpg",
        "/images/projeto-terra-3.jpg",
        "/images/projeto-terra-4.jpg",
        "/images/projeto-terra-5.jpg",
        "/images/projeto-terra-6.jpg",
        "/images/projeto-terra-7.jpg"
    };

    private readonly List<string> detetiveImages = new()
    {
        "/images/detetive-toxicologico.jpg",
        "/images/detetive-toxicologico-2.jpg",
        "/images/detetive-toxicologico-3.jpg",
        "/images/detetive-toxicologico-4.jpg",
        "/images/detetive-toxicologico-5.jpg"
    };

    private readonly List<string> resgateNatalinoImages = new()
    {
        "/images/resgate-natalino.jpg",
        "/images/resgate-natalino2.jpg",
        "/images/resgate-natalino3.jpg"
    };

    private readonly List<string> bandoletesImages = new()
    {
        "/images/bandoletes.jpg"
    };

    private void OpenGallery(List<string> gallery, int startIndex)
    {
        currentGallery = gallery;
        currentImageIndex = startIndex;
        showLightbox = true;
    }

    private void CloseGallery()
    {
        showLightbox = false;
    }

    private void NextImage()
    {
        if (currentGallery.Count == 0) return;
        currentImageIndex = (currentImageIndex + 1) % currentGallery.Count;
    }

    private void PrevImage()
    {
        if (currentGallery.Count == 0) return;
        currentImageIndex = (currentImageIndex - 1 + currentGallery.Count) % currentGallery.Count;
    }

    private bool showGame = false;

    private void OpenGame()
    {
        showGame = true;
    }

    private void CloseGame()
    {
        showGame = false;
    }
}